# Copy this file to .env and fill in values
# Never commit .env to version control

JWT_SECRET=replace_with_a_long_random_secret_string
PORT=3001
NODE_ENV=development

# Set this to your Vercel frontend URL once deployed (e.g. https://studypulse.vercel.app)
FRONTEND_URL=

# Anthropic API key for Claude (required for the study design extractor)
ANTHROPIC_API_KEY=

# Tutor email address (case-insensitive) — only this account can access /api/v1/tutor-data
TUTOR_EMAIL=
